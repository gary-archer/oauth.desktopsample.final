    "tailwindcss": "^4.3.0",
    "undici": "^8.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.3",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-modal": "^3.16.3",
    "electron": "^42.3.0",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
