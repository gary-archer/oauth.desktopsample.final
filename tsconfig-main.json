{
  "compilerOptions": {
    "strict": true,
    "target": "ES2025",
    "lib": ["ES2025"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "sourceMap": true,
    "rootDir": "src"
  },
  "include": [
    "src/main.ts",
    "src/main/**/*.ts",
    "src/shared/**/*.ts",
  ],
  "exclude": [
    "node_modules"
  ]
}
